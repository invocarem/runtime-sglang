# DGX Spark runtime configuration for spark_runtime.py
# Copy to .env and adjust values as needed.

# Cluster nodes
MASTER_NODE=spark1
WORKER_NODE=spark2

# Ports
MASTER_PORT=29500
SERVER_PORT=30000

# Model and parallelism
MODEL_PATH=/home/chenchen/huggingface/Qwen_Qwen3.5-2B
# Used when not using a preset, or when the preset omits "tp". With --preset, model_presets.json "tp" wins.
TP_SIZE=1
VENV_PATH=~/.sglang

# Optional overrides
REMOTE_DIR=~/runtime-sglang
# DIST_ADDR defaults to "${MASTER_NODE}:${MASTER_PORT}" if not set
# DIST_ADDR=spark1:29500
# MODEL_PRESET defaults to empty (no preset)
# MODEL_PRESET=qwen3.5-2b
# MODEL_PRESETS_FILE defaults to model_presets.json
# MODEL_PRESETS_FILE=./model_presets.json
# SGLANG_EXTRA_ARGS are appended after preset args, e.g.:
# SGLANG_EXTRA_ARGS=--enable-metrics --context-length 32768 --mem-fraction-static 0.7 --trust-remote-code

# NCCL / RoCE settings
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_IB_TIMEOUT=22
NCCL_IB_RETRY_CNT=7
NCCL_IB_SL=3
NCCL_IB_TC=160
NCCL_IB_QPS_PER_CONNECTION=4
NCCL_IB_CUDA_SUPPORT=1
NCCL_NET_GDR_LEVEL=5
NCCL_NET_GDR_READ=1
NCCL_P2P_DISABLE=0
NCCL_IB_HCA=mlx5,roce
NCCL_PROTO=Simple
NCCL_ALGO=Ring

# Network interface binding
CX7_IFACE=enp1s0f1np1
NCCL_SOCKET_IFNAME=enp1s0f1np1
NCCL_IB_IFNAME=enp1s0f1np1

# Runtime behavior
NCCL_DEBUG=WARN
CUDA_GRAPHS=1
SGLANG_DISABLE_TORCHVISION=1
